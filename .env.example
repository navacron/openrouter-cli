# Copy this file to .env and fill in your key: cp .env.example .env
# orouter (via python-dotenv) loads .env automatically, searching upward from
# the current directory. Real environment variables always take precedence.

# Required. Create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: default models per command, overridable with --model
OPENROUTER_MODEL=
OPENROUTER_IMAGE_MODEL=
OPENROUTER_VIDEO_MODEL=

# Optional: advanced API base URL override
OPENROUTER_BASE_URL=
